@model BaiTapThucHanh.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<h1>Thêm danh mục mới</h1>

<form asp-action="Add">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Tên danh mục</label>
        <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục (ví dụ: Điện thoại, Laptop...)" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Thêm mới</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</form>