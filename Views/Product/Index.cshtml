@model IEnumerable<BaiTapThucHanh.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<h2 class="mb-4">Danh sách sản phẩm</h2>

<p>
    <a asp-action="Add" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
    </a>
</p>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-light text-center">
        <tr>
            <th style="width: 20%;">Tên sản phẩm</th>
            <th style="width: 15%;">Hình ảnh</th>
            <th style="width: 15%;">Danh mục</th>
            <th style="width: 15%;">Giá bán</th>
            <th style="width: 15%;">Mô tả</th>
            <th style="width: 20%;">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                <tr>
                    <td class="fw-bold">@product.Name</td>
                    <td class="text-center">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="/images/@product.ImageUrl" width="80" height="80" class="img-thumbnail" style="object-fit: cover;" alt="@product.Name" />
                        }
                        else
                        {
                            <span class="text-muted text-italic" style="font-size: 0.85rem;">Không có ảnh</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (product.Category != null)
                        {
                            <span class="badge bg-secondary">@product.Category.Name</span>
                        }
                        else
                        {
                            <span class="text-muted small">Chưa phân loại</span>
                        }
                    </td>
                    <td class="text-end text-danger fw-bold">
                        @product.Price.ToString("#,##0") VNĐ
                    </td>
                    <td>
                        <span class="text-truncate d-inline-block" style="max-width: 180px;" title="@product.Description">
                            @product.Description
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-info btn-sm text-white">Xem</a>
                            <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-warning btn-sm text-white mx-1">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm">Xóa</a>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted p-4">Hiện chưa có sản phẩm nào trong hệ thống.</td>
            </tr>
        }
    </tbody>
</table>