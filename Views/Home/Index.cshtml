@model IEnumerable<BaiTapThucHanh.Models.Product>

@{
    ViewData["Title"] = "Trang chủ - Cửa hàng";
}

<div class="container">
    <h3 class="pb-2 border-bottom mb-4">Sản phẩm nổi bật</h3>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 position-relative">

                        <div class="text-center bg-light rounded-top p-3" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@Url.Content($"~/images/{product.ImageUrl}")" class="card-img-top" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@product.Name" />
                            }
                            else
                            {
                                <div class="text-muted text-center">
                                    <i class="bi bi-image" style="font-size: 3rem;"></i><br />
                                    <span style="font-size: 0.85rem;">Không có ảnh</span>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-dark fw-bold mb-2">@product.Name</h5>

                            <p class="card-text text-muted text-truncate small mb-3" title="@product.Description">
                                @product.Description
                            </p>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-danger fw-bold fs-5">@product.Price.ToString("#,##0") VNĐ</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer p-0 border-top-0">
                            <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-primary w-100 rounded-bottom">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 w-100 text-center text-muted py-5">
                <p class="fs-5">Hiện tại hệ thống cửa hàng chưa có sản phẩm nào đăng bán.</p>
            </div>
        }
    </div>
</div>